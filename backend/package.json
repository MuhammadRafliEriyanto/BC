{
  "name": "bimbel-new-backend",
  "version": "1.0.0",
  "description": "Backend authentication service for Bimbel LMS",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "schedules:generate:dry-run": "tsx src/scripts/generateTeacherSchedules.ts",
    "schedules:generate": "tsx src/scripts/generateTeacherSchedules.ts --apply",
    "schedules:generate:allow-orphans": "tsx src/scripts/generateTeacherSchedules.ts --apply --allow-learning-orphans",
    "schedules:generate:slawi:dry-run": "tsx src/scripts/generateTeacherSchedules.ts --branch=Slawi",
    "schedules:generate:slawi": "tsx src/scripts/generateTeacherSchedules.ts --branch=Slawi --apply --allow-learning-orphans",
    "schedules:generate:adiwerna:dry-run": "tsx src/scripts/generateTeacherSchedules.ts --branch=Adiwerna",
    "schedules:generate:adiwerna": "tsx src/scripts/generateTeacherSchedules.ts --branch=Adiwerna --apply --allow-learning-orphans",
    "schedules:generate:adiwerna:from-slawi-classes:dry-run": "tsx src/scripts/generateTeacherSchedules.ts --branch=Adiwerna --class-source-branch=Slawi",
    "schedules:generate:adiwerna:from-slawi-classes": "tsx src/scripts/generateTeacherSchedules.ts --branch=Adiwerna --class-source-branch=Slawi --apply --allow-learning-orphans",
    "data:teachers:adiwerna:restore:dry-run": "tsx src/scripts/restoreAdiwernaTeacherData.ts",
    "data:teachers:adiwerna:restore": "tsx src/scripts/restoreAdiwernaTeacherData.ts --apply",
    "data:students:adiwerna:from-excel:dry-run": "tsx src/scripts/importAdiwernaStudentsFromExcel.ts",
    "data:students:adiwerna:from-excel": "tsx src/scripts/importAdiwernaStudentsFromExcel.ts --apply",
    "data:finance:seed:dry-run": "tsx src/scripts/seedBranchFinanceData.ts",
    "data:finance:seed": "tsx src/scripts/seedBranchFinanceData.ts --apply",
    "data:learning:seed:dry-run": "tsx src/scripts/seedTeacherLearningMeetings.ts",
    "data:learning:seed": "tsx src/scripts/seedTeacherLearningMeetings.ts --apply",
    "data:teachers:merge-branches:dry-run": "tsx src/scripts/mergeDuplicateBranchTeachers.ts",
    "data:teachers:merge-branches": "tsx src/scripts/mergeDuplicateBranchTeachers.ts --apply",
    "data:schedules:reduce-adiwerna:dry-run": "tsx src/scripts/reduceAdiwernaTeacherSchedules.ts",
    "data:schedules:reduce-adiwerna": "tsx src/scripts/reduceAdiwernaTeacherSchedules.ts --apply",
    "data:tryouts:import:dry-run": "tsx src/scripts/importAssessmentTryouts.ts",
    "data:tryouts:import": "tsx src/scripts/importAssessmentTryouts.ts --apply",
    "data:rollback:adiwerna-seed:dry-run": "tsx src/scripts/rollbackAdiwernaSeedData.ts",
    "data:rollback:adiwerna-seed": "tsx src/scripts/rollbackAdiwernaSeedData.ts --apply",
    "data:cleanup:dry-run": "tsx src/scripts/cleanupScheduleData.ts",
    "data:cleanup": "tsx src/scripts/cleanupScheduleData.ts --apply",
    "data:cleanup:slawi": "tsx src/scripts/cleanupScheduleData.ts --apply --fill-empty-branch=Slawi",
    "audit:student-master:dry-run": "tsx src/scripts/studentMasterCleanupDryRun.ts",
    "audit:student-master:apply": "tsx src/scripts/studentMasterCleanupApply.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0",
    "nodemailer": "^6.10.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "@types/nodemailer": "^7.0.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
